# Anthropic API (server-side only — never prefix with NEXT_PUBLIC_)
ANTHROPIC_API_KEY=

# Neon Postgres (from your Neon project dashboard → Connection Details)
DATABASE_URL=

# Upstash Redis (free tier at upstash.com)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Resend (contact form emails — free at resend.com)
RESEND_API_KEY=

# Optional: restrict chat API to your domain only
# ALLOWED_ORIGIN=https://johnmoorman.com
